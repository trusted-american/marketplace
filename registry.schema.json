{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Marketplace Registry",
  "type": "object",
  "required": ["version", "plugins", "community"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Registry schema version"
    },
    "plugins": {
      "type": "array",
      "description": "Original plugins by Trusted American Organization",
      "items": {
        "type": "object",
        "required": ["name", "path", "description"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string", "description": "Relative path under plugins/" },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "community": {
      "type": "array",
      "description": "Forked or linked third-party plugins",
      "items": {
        "type": "object",
        "required": ["name", "path", "description", "upstream"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string", "description": "Relative path under community/" },
          "description": { "type": "string" },
          "upstream": { "type": "string", "description": "URL to the original repo or plugin" },
          "version": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
