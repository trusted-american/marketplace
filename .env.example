# Marketplace Environment Configuration
# Copy to .env and fill in values.
# Only ATLASSIAN_CLOUD_ID and JIRA_DEFAULT_PROJECT are needed for basic Jira integration.
# Everything else is optional.

# ── Atlassian (required for Jira/Confluence) ──────────────────
# Get your Cloud ID by running: getAccessibleAtlassianResources
# via the Atlassian MCP server in Claude Code.
ATLASSIAN_CLOUD_ID=
JIRA_DEFAULT_PROJECT=

# ── Database (optional — jira-orchestrator persistence) ───────
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=jira-orchestrator

# ── Harness CI/CD (optional) ─────────────────────────────────
HARNESS_ACCOUNT_ID=
HARNESS_API_KEY=
HARNESS_ORG_ID=default
HARNESS_PROJECT_ID=

# ── GitHub (optional — PR creation) ──────────────────────────
GITHUB_TOKEN=

# ── Notifications (optional) ─────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
