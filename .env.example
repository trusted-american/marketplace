# ============================================
# Jira Orchestrator v7.5.0 Configuration
# ============================================

# --------------------------------------------
# Atlassian Configuration (Required)
# --------------------------------------------
# Your Atlassian Cloud ID - get this from the OAuth flow or:
# Run: claude mcp invoke atlassian getAccessibleAtlassianResources
ATLASSIAN_CLOUD_ID=your-cloud-id-here

# Default Jira project key (e.g., "PROJ", "DEV", "ENG")
JIRA_DEFAULT_PROJECT=PROJ

# --------------------------------------------
# Database Infrastructure (v7.5.0)
# --------------------------------------------
# Neon PostgreSQL - Serverless database for persistent state
# Get free tier at: https://neon.tech
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Redis - High-performance caching
# Local: redis://localhost:6379
# Cloud: redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# Temporal - Durable workflow execution
# Local: localhost:7233
# Cloud: your-namespace.tmprl.cloud:7233
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=jira-orchestrator

# --------------------------------------------
# Harness CD/CI (Optional)
# --------------------------------------------
# Get PAT from: https://app.harness.io/ng/account/[account]/settings/access-management/users
HARNESS_ACCOUNT_ID=your-account-id
HARNESS_API_KEY=pat.your-pat-token
HARNESS_ORG_ID=default
HARNESS_PROJECT_ID=your-project-id

# --------------------------------------------
# GitHub (Optional - for PR creation)
# --------------------------------------------
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# --------------------------------------------
# Notifications (Optional)
# --------------------------------------------
# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# PagerDuty integration key
PAGERDUTY_INTEGRATION_KEY=your-integration-key
